# Neon (Netlify DB / Postgres)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Netlify Identity (enable in Netlify UI; no keys needed in env for basic auth)
# NETLIFY_IDENTITY_URL=https://your-site.netlify.app

# AI APIs (one failing will auto-fallback to next; store in Netlify env)
DEEPSEEK_API_KEY=
GLM_API_KEY=
MOONSHOT_API_KEY=
TONGYI_API_KEY=
TENCENT_API_KEY=
SPARK_API_KEY=
DOUBAO_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPAI_API_KEY=

# Analytics (UTM tracking)
NEXT_PUBLIC_BAIDU_ANALYTICS_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# SendGrid (for Agent-Sales email sending)
SENDGRID_API_KEY=

# Enterprise WeChat webhook (for urgent notifications)
WECHAT_WORK_WEBHOOK_URL=
